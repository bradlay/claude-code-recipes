#!/usr/bin/env python3
# Quality-report entry point. Reads cycle logs written by chain._save_cycle_log
# and reports primary-vs-shadow agreement so users running
# CLAUDE_PLAN_REVIEW_SHADOW=local (or another provider) can measure how a
# candidate provider compares to their primary.

from __future__ import annotations

import sys
from pathlib import Path

_SCRIPTS = Path(__file__).resolve().parent.parent / "scripts"
sys.path.insert(0, str(_SCRIPTS))

from quality_report import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
