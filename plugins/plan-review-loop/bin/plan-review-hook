#!/bin/sh
# Plan-review hook launcher for Claude Code's PreToolUse(ExitPlanMode).
#
# Fails closed (denies ExitPlanMode) when prereqs are missing, including
# python3 itself (the .py hook can't check for python3 because it can't
# run without it).
# Set CLAUDE_PLAN_REVIEW_FAIL_OPEN=1 to bypass.

set -eu

emit_deny() {
    reason="$1"
    printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"plan-review-loop: %s"}}\n' "$reason"
    exit 0
}

if [ "${CLAUDE_PLAN_REVIEW_FAIL_OPEN:-0}" = "1" ]; then
    bypass_on_missing=1
else
    bypass_on_missing=0
fi

if ! command -v python3 >/dev/null 2>&1; then
    if [ "$bypass_on_missing" = "1" ]; then
        exit 0
    fi
    emit_deny "python3 not on PATH. Install Python 3.10+ or set CLAUDE_PLAN_REVIEW_FAIL_OPEN=1 to bypass."
fi

dir="$(dirname "$0")"
exec python3 "$dir/../scripts/plan_review_hook.py" "$@"
