#!/bin/sh
# PostToolUse(Bash) audit hook launcher. Always fail-open: if python3 is
# missing the bash command runs unaudited (no security implication; the
# audit log is a convenience, not a gate).

set -eu

if ! command -v python3 >/dev/null 2>&1; then
    exit 0
fi

dir="$(dirname "$0")"
exec python3 "$dir/../scripts/audit_hook.py" "$@"
