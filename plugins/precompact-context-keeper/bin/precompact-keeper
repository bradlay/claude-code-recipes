#!/bin/sh
# PreCompact hook launcher. Fail-open: if python3 is missing, compaction
# proceeds without the injection (no security implication; this hook is
# informational, not a gate).

set -eu

if ! command -v python3 >/dev/null 2>&1; then
    exit 0
fi

dir="$(dirname "$0")"
exec python3 "$dir/../scripts/precompact_hook.py" "$@"
