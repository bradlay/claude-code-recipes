{
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "Plan",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/subagent-context\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Explore",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/subagent-context\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
