#!/bin/sh
# Stop hook launcher. Always fail-open: if python3 is missing the
# session ends without the checklist (no security implication; the
# hook is informational).

set -eu

if ! command -v python3 >/dev/null 2>&1; then
    exit 0
fi

dir="$(dirname "$0")"
exec python3 "$dir/../scripts/stop_check_hook.py" "$@"
